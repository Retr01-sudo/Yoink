# App
PORT=3000
NODE_ENV=development

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=inventory
POSTGRES_PORT=5433

DATABASE_URL=postgresql://postgres:your_password@localhost:5433/inventory

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Redis Commander GUI
REDIS_COMMANDER_PORT=8081

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000

# Grafana
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASS=admin

# Prometheus
PROM_PORT=9090
WORKER_METRICS_PORT=3002
DLQWORKER_METRICS_PORT=3003
